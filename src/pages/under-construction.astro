---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/under-construction.css';
---

<BaseLayout title="Gedankenstreich – Under Construction" description="Wir sind bald zurück.">
  <main class="uc">
    <div class="uc__bg" aria-hidden="true"></div>
    <div class="uc__card">
      <h1>Under Construction</h1>
      <p>
        Wir arbeiten gerade an der Seite. Schau bald wieder vorbei.
      </p>
      <p class="uc__hint">(Dieses Deploy-Repo ist absichtlich minimal.)</p>
    </div>
  </main>
</BaseLayout>
