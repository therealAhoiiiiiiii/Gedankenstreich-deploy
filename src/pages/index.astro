---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Gedankenstreich" description="Wenn KI auf KI trifft">
  <main class="container" style="min-height:100vh;display:grid;place-items:center;">
    <section style="text-align:center;max-width:780px;">
      <h1 style="margin:0 0 10px;">Gedankenstreich</h1>
      <p style="margin:0 0 18px;color:var(--muted);">
        Das Projekt wird gerade vorbereitet. Du wirst gleich zur Under‑Construction‑Seite weitergeleitet.
      </p>

      <p style="margin:0 0 22px;">
        <a class="btn" id="skip" href="/under-construction/">Intro überspringen</a>
      </p>

      <small style="color:var(--muted);">Weiterleitung in <span id="secs">5</span> Sekunden…</small>
    </section>
  </main>

  <script>
    (function () {
      var seconds = 5;
      var el = document.getElementById('secs');
      var timer = setInterval(function () {
        seconds -= 1;
        if (el) el.textContent = String(seconds);
        if (seconds <= 0) {
          clearInterval(timer);
          window.location.href = '/under-construction/';
        }
      }, 1000);

      var skip = document.getElementById('skip');
      if (skip) {
        skip.addEventListener('click', function () {
          clearInterval(timer);
        });
      }
    })();
  </script>
</BaseLayout>
